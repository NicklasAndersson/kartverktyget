# Mall för .env i repo-roten. Kopiera till `.env` och fyll i värdena.
# .env är gitignorerad — checka aldrig in riktiga nycklar.
#
#   cp .env.example .env
#
# ---------------------------------------------------------------------------
# Backblaze B2 (S3-kompatibelt API) – används av scripts/upload-pmtiles-b2.sh
# ---------------------------------------------------------------------------
# Application Key i B2-konsolen. Skapa en *bucket-specifik* nyckel med
# rättigheterna "listBuckets, listFiles, readFiles, writeFiles" mot mål-bucketen.
B2_KEY_ID=
B2_APPLICATION_KEY=

# Bucket-namn (case-känsligt) och dess S3-endpoint/region.
# Endpointen visas under "Endpoint" på bucket-sidan i B2-konsolen.
B2_BUCKET=kartverktyget
B2_ENDPOINT=https://s3.eu-central-003.backblazeb2.com
B2_REGION=eu-central-003

# Objektnyckel i bucketen (default i upload-skriptet: sweden-lm.pmtiles).
# Sätt B2_KEY=sweden-osm.pmtiles när OSM-PMTiles laddas upp.
# B2_KEY=sweden-lm.pmtiles

# ---------------------------------------------------------------------------
# Hetzner-byggserver – används av scripts/build-lm-pmtiles-remote.sh
# ---------------------------------------------------------------------------
# IP eller hostname, SSH-user och arbetskatalog på servern.
LM_REMOTE_HOST=178.105.223.176
LM_REMOTE_USER=root
LM_REMOTE_DIR=/root/kvg

# Sökväg till råleveransen från Lantmäteriets uttagstjänst (lokalt).
# Default pekar på exempel-UUID; uppdatera när en ny leverans tas hem.
LM_RAW_DIR=data/raw/lantmäteriet/bb7631cc-81ee-4bd0-aa8b-2a23714cb259

# Var den färdiga PMTiles-filen hamnar lokalt när bygget hämtas hem.
LM_OUT_PMTILES=data/sweden-lm.pmtiles

# Extra SSH-flaggor (t.ex. annan nyckel). Lämna tom om standard fungerar.
# LM_SSH_OPTS=-i ~/.ssh/id_ed25519_kvg

# ---------------------------------------------------------------------------
# PMTiles-källor – runtime-konfiguration (dev, docker, produktion)
# ---------------------------------------------------------------------------
# Dessa variabler läses av API-servern vid start. De styr vilka tile-filer
# som används och skriver om source-URL:erna i stilarna dynamiskt.
# Källans namn (OSM/LM) matchas mot stilarna: "osm" = Protomaps, "lm" = Lantmäteriet.
#
# Fyll i dina egna URL:er här – filen är gitignorerad och committas aldrig.
#
# Variant A – publik fjärr-URL (browsern hämtar direkt, ingen proxy):
PMTILES_OSM_URL=https://your-bucket.example.com/sweden-osm.pmtiles
PMTILES_OSM_PUBLIC=true
PMTILES_LM_URL=https://your-bucket.example.com/sweden-lm.pmtiles
PMTILES_LM_PUBLIC=true
#
# Variant B – lokal fil (mountas på /data i containern):
# PMTILES_OSM_FILE=/data/sweden-osm.pmtiles
# PMTILES_LM_FILE=/data/sweden-lm.pmtiles
#
# Variant C – privat fjärr-URL (API:n proxar, credentials läcker aldrig ut):
# PMTILES_OSM_URL=https://private.example.com/sweden-osm.pmtiles
# PMTILES_OSM_AUTH=Bearer ditt-token-här
# PMTILES_OSM_PUBLIC=false

# Om containern körs bakom en reverse-proxy med annan publik host,
# sätt explicit public base-URL (annars härleds den från X-Forwarded-*).
# KVG_PUBLIC_BASE_URL=https://karta.example.com
