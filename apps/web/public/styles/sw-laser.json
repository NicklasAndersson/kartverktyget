{
  "version": 8,
  "name": "Svartvitt (laser)",
  "glyphs": "https://protomaps.github.io/basemaps-assets/fonts/{fontstack}/{range}.pbf",
  "sources": {
    "osm": {
      "type": "vector",
      "url": "/tiles/sweden.json"
    }
  },
  "layers": [
    { "id": "background", "type": "background", "paint": { "background-color": "#ffffff" } },
    {
      "id": "earth",
      "type": "fill",
      "source": "osm",
      "source-layer": "earth",
      "paint": { "fill-color": "#ffffff" }
    },
    {
      "id": "landcover-wood",
      "type": "fill",
      "source": "osm",
      "source-layer": "landcover",
      "filter": ["==", ["get", "kind"], "wood"],
      "paint": { "fill-color": "#ffffff", "fill-outline-color": "#000" }
    },
    {
      "id": "landcover-wood-pattern",
      "type": "line",
      "source": "osm",
      "source-layer": "landcover",
      "filter": ["==", ["get", "kind"], "wood"],
      "paint": { "line-color": "#000", "line-width": 0.4, "line-opacity": 0.5 }
    },
      {
        "id": "landuse-wood",
        "type": "fill",
        "source": "osm",
        "source-layer": "landuse",
        "filter": ["any", ["==", ["get", "kind"], "forest"], ["==", ["get", "kind"], "wood"], ["==", ["get", "kind"], "scrub"], ["==", ["get", "kind"], "nature_reserve"]],
        "paint": { "fill-color": "#f0f0f0", "fill-outline-color": "#000" }
      },
      {
        "id": "landuse-open",
        "type": "fill",
        "source": "osm",
        "source-layer": "landuse",
        "filter": ["any", ["==", ["get", "kind"], "meadow"], ["==", ["get", "kind"], "grass"], ["==", ["get", "kind"], "grassland"], ["==", ["get", "kind"], "farmland"], ["==", ["get", "kind"], "garden"], ["==", ["get", "kind"], "allotments"], ["==", ["get", "kind"], "golf_course"], ["==", ["get", "kind"], "recreation_ground"], ["==", ["get", "kind"], "pitch"], ["==", ["get", "kind"], "playground"], ["==", ["get", "kind"], "wetland"]],
        "paint": { "fill-color": "#f7f7f7", "fill-outline-color": "#999999" }
      },
    {
      "id": "water",
      "type": "fill",
      "source": "osm",
      "source-layer": "water",
      "paint": { "fill-color": "#ffffff" }
    },
    {
      "id": "water-outline",
      "type": "line",
      "source": "osm",
      "source-layer": "water",
      "paint": { "line-color": "#000", "line-width": 0.7 }
    },
    {
      "id": "buildings",
      "type": "fill",
      "source": "osm",
      "source-layer": "buildings",
      "minzoom": 13,
      "paint": { "fill-color": "#000" }
    },
    {
      "id": "roads-track",
      "type": "line",
      "source": "osm",
      "source-layer": "roads",
      "filter": ["==", ["get", "kind"], "track"],
      "paint": {
        "line-color": "#000",
        "line-width": ["interpolate", ["linear"], ["zoom"], 10, 0.3, 16, 0.8],
        "line-dasharray": [4, 3]
      }
    },
    {
      "id": "roads-path",
      "type": "line",
      "source": "osm",
      "source-layer": "roads",
      "filter": ["==", ["get", "kind"], "path"],
      "paint": {
        "line-color": "#000",
        "line-width": ["interpolate", ["linear"], ["zoom"], 10, 0.5, 16, 1.2],
        "line-dasharray": [3, 2]
      }
    },
    {
      "id": "roads-minor",
      "type": "line",
      "source": "osm",
      "source-layer": "roads",
      "filter": ["any", ["==", ["get", "kind"], "minor_road"], ["==", ["get", "kind"], "medium_road"]],
      "paint": {
        "line-color": "#000",
        "line-width": ["interpolate", ["linear"], ["zoom"], 10, 0.5, 16, 1.8]
      }
    },
    {
      "id": "roads-major",
      "type": "line",
      "source": "osm",
      "source-layer": "roads",
      "filter": ["==", ["get", "kind"], "major_road"],
      "paint": {
        "line-color": "#000",
        "line-width": ["interpolate", ["linear"], ["zoom"], 8, 0.8, 16, 4.5]
      }
    },
    {
      "id": "roads-highway",
      "type": "line",
      "source": "osm",
      "source-layer": "roads",
      "filter": ["==", ["get", "kind"], "highway"],
      "paint": {
        "line-color": "#000",
        "line-width": ["interpolate", ["linear"], ["zoom"], 6, 1.2, 16, 7]
      }
    },
    {
      "id": "road-labels-major",
      "type": "symbol",
      "source": "osm",
      "source-layer": "roads",
      "minzoom": 11,
      "filter": ["any", ["==", ["get", "kind"], "major_road"], ["==", ["get", "kind"], "highway"]],
      "layout": {
        "symbol-placement": "line",
        "text-field": ["coalesce", ["get", "name:sv"], ["get", "name"]],
        "text-font": ["Noto Sans Medium"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 11, 11.5, 16, 13.5],
        "symbol-spacing": 350,
        "text-keep-upright": true,
        "text-max-angle": 35
      },
      "paint": { "text-color": "#000", "text-halo-color": "#fff", "text-halo-width": 2 }
    },
    {
      "id": "road-labels-minor",
      "type": "symbol",
      "source": "osm",
      "source-layer": "roads",
      "minzoom": 13,
      "filter": ["any", ["==", ["get", "kind"], "medium_road"], ["==", ["get", "kind"], "minor_road"]],
      "layout": {
        "symbol-placement": "line",
        "text-field": ["coalesce", ["get", "name:sv"], ["get", "name"]],
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 13, 10.5, 16, 12],
        "symbol-spacing": 300,
        "text-keep-upright": true,
        "text-max-angle": 35
      },
      "paint": { "text-color": "#000", "text-halo-color": "#fff", "text-halo-width": 1.75 }
    },
    {
      "id": "place-labels",
      "type": "symbol",
      "source": "osm",
      "source-layer": "places",
      "layout": {
        "text-field": ["coalesce", ["get", "name:sv"], ["get", "name"]],
        "text-font": ["Noto Sans Medium"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 8, 12.5, 14, 16.5]
      },
      "paint": { "text-color": "#000", "text-halo-color": "#fff", "text-halo-width": 2 }
    }
  ]
}
